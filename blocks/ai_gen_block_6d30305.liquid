{% doc %}
  @prompt
    Structure:
    
    Add a section titled “Session Gear”
    
    Include a horizontal, scrollable product carousel
    
    Each product card should include:
    
    product image
    
    product name
    
    price
    
    “View product” or “Quick add” button
    
    Artist Filtering:
    
    At the top of the section, include a row of artist filter buttons (e.g. Tony, John, Pete, All)
    
    When an artist is selected, only show products associated with that artist
    
    Include an “All Gear” option to show all products
    
    Each product should be manually assigned to an artist within the section settings
    
    Functionality:
    
    Filtering should happen instantly on click (no page reload)
    
    When switching artists, reset the carousel scroll to the beginning
    
    Products should not reload or break layout when filtering
    
    Design:
    
    clean, minimal, performance-focused
    
    consistent with Vic Firth styling (black, white, light gray, strong typography)
    
    product cards should feel premium, not cluttered
    
    maintain strong spacing and alignment
    
    Layout:
    
    desktop: horizontal carousel with multiple products visible
    
    mobile: swipeable horizontal scroll
    
    ensure smooth scrolling and no layout shifting
    
    IMPORTANT:
    
    Scope all styles and functionality ONLY to this section
    
    Do not apply global styles to buttons, divs, or product cards
    
    Do not affect any other sections on the site
    
    Optional enhancements:
    
    allow one product to appear under multiple artists
    
    include a small label like “Used in session” on product cards
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-session-gear-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-session-gear-container-{{ ai_gen_id }} {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 28px;
  }

  .ai-session-gear-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-session-gear-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 24px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-session-gear-filters-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }} {
    padding: 10px 24px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 1px solid {{ block.settings.filter_border_color }};
    border-radius: 40px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.filter_hover_bg_color }};
    color: {{ block.settings.filter_hover_text_color }};
    border-color: {{ block.settings.filter_hover_border_color }};
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_border_color }};
  }

  .ai-session-gear-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-session-gear-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 20px;
  }

  .ai-session-gear-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-session-gear-product-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: 280px;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: 0;
    overflow: hidden;
    transition: opacity 0.3s ease;
  }

  .ai-session-gear-product-card-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-session-gear-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background-color: #f8f8f9;
    overflow: hidden;
  }

  .ai-session-gear-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-session-gear-product-label-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.label_bg_color }};
    color: {{ block.settings.label_text_color }};
    padding: 6px 12px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 40px;
    font-weight: 700;
  }

  .ai-session-gear-product-info-{{ ai_gen_id }} {
    padding: 20px 0;
  }

  .ai-session-gear-product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 16px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  .ai-session-gear-product-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 16px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-session-gear-product-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: 40px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-session-gear-product-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-session-gear-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-session-gear-{{ ai_gen_id }} {
      padding: 40px 0;
    }

    .ai-session-gear-container-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-session-gear-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
      margin-bottom: 20px;
    }

    .ai-session-gear-product-card-{{ ai_gen_id }} {
      width: 240px;
    }

    .ai-session-gear-carousel-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<session-gear-{{ ai_gen_id }} class="ai-session-gear-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-session-gear-container-{{ ai_gen_id }}">
    <div class="ai-session-gear-header-{{ ai_gen_id }}">
      {% if block.settings.section_title != blank %}
        <h2 class="ai-session-gear-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      {% endif %}

      <div class="ai-session-gear-filters-{{ ai_gen_id }}">
        <button
          class="ai-session-gear-filter-btn-{{ ai_gen_id }} active"
          data-filter="all"
        >
          All Gear
        </button>
        {% if block.settings.artist_1_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-filter="artist1"
          >
            {{ block.settings.artist_1_name }}
          </button>
        {% endif %}
        {% if block.settings.artist_2_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-filter="artist2"
          >
            {{ block.settings.artist_2_name }}
          </button>
        {% endif %}
        {% if block.settings.artist_3_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-filter="artist3"
          >
            {{ block.settings.artist_3_name }}
          </button>
        {% endif %}
        {% if block.settings.artist_4_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-filter="artist4"
          >
            {{ block.settings.artist_4_name }}
          </button>
        {% endif %}
      </div>
    </div>

    <div class="ai-session-gear-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-session-gear-carousel-{{ ai_gen_id }}">
        {% assign has_products = false %}
        {% for i in (1..12) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign artist_key = 'product_' | append: i | append: '_artists'
            assign product = block.settings[product_key]
            assign artists = block.settings[artist_key]
          %}

          {% if product != blank %}
            {% assign has_products = true %}
            <div
              class="ai-session-gear-product-card-{{ ai_gen_id }}"
              data-artists="{{ artists }}"
            >
              <div class="ai-session-gear-product-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-session-gear-product-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-session-gear-product-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                {% if block.settings.show_label %}
                  <div class="ai-session-gear-product-label-{{ ai_gen_id }}">
                    {{ block.settings.label_text }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-session-gear-product-info-{{ ai_gen_id }}">
                <h3 class="ai-session-gear-product-title-{{ ai_gen_id }}">
                  {{ product.title }}
                </h3>
                <div class="ai-session-gear-product-price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>
                <a
                  href="{{ product.url }}"
                  class="ai-session-gear-product-btn-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {% unless has_products %}
          <div class="ai-session-gear-empty-state-{{ ai_gen_id }}">
            Add products to display in this carousel
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</session-gear-{{ ai_gen_id }}>

<script>
  (function() {
    class SessionGear{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-session-gear-filter-btn-{{ ai_gen_id }}');
        this.productCards = this.querySelectorAll('.ai-session-gear-product-card-{{ ai_gen_id }}');
        this.carousel = this.querySelector('.ai-session-gear-carousel-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.filterButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            this.handleFilterClick(e.target);
          });
        });
      }

      handleFilterClick(button) {
        const filter = button.getAttribute('data-filter');

        this.filterButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        this.carousel.scrollTo({ left: 0, behavior: 'smooth' });

        this.productCards.forEach((card) => {
          const cardArtists = card.getAttribute('data-artists');

          if (filter === 'all') {
            card.classList.remove('hidden');
          } else {
            if (cardArtists && cardArtists.includes(filter)) {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          }
        });
      }
    }

    customElements.define('session-gear-{{ ai_gen_id }}', SessionGear{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Create a section that combines a image and a slection of multiple products. This will be a content blokc that can feature a specific artists picture and a carousel portion that showcaes whaqt products they used.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-artist-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-artist-showcase-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-artist-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-artist-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-artist-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-artist-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-artist-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-artist-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-artist-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.artist_name_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-artist-bio-{{ ai_gen_id }} {
    font-size: {{ block.settings.bio_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-products-section-{{ ai_gen_id }} {
    margin-top: 24px;
  }

  .ai-products-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.products_heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
  }

  .ai-products-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-products-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 8px;
  }

  .ai-products-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: 200px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: 12px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-carousel-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    justify-content: center;
  }

  .ai-carousel-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-carousel-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-empty-products-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    background-color: #f9f9f9;
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-artist-showcase-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-product-card-{{ ai_gen_id }} {
      width: 160px;
    }

    .ai-artist-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.artist_name_size }}px * 0.8);
    }

    .ai-artist-bio-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.bio_size }}px * 0.9);
    }
  }
{% endstyle %}

<artist-showcase-{{ ai_gen_id }}
  class="ai-artist-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-artist-showcase-container-{{ ai_gen_id }}">
    <div class="ai-artist-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.artist_image %}
        <img
          src="{{ block.settings.artist_image | image_url: width: 800 }}"
          alt="{{ block.settings.artist_name | escape }}"
          loading="lazy"
          width="{{ block.settings.artist_image.width }}"
          height="{{ block.settings.artist_image.height }}"
          class="ai-artist-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-artist-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-artist-empty-state-{{ ai_gen_id }}">
            Add an artist image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-artist-info-{{ ai_gen_id }}">
      {% if block.settings.artist_name != blank %}
        <h2 class="ai-artist-name-{{ ai_gen_id }}">{{ block.settings.artist_name }}</h2>
      {% endif %}

      {% if block.settings.artist_bio != blank %}
        <div class="ai-artist-bio-{{ ai_gen_id }}">{{ block.settings.artist_bio }}</div>
      {% endif %}

      <div class="ai-products-section-{{ ai_gen_id }}">
        {% if block.settings.products_heading != blank %}
          <h3 class="ai-products-heading-{{ ai_gen_id }}">{{ block.settings.products_heading }}</h3>
        {% endif %}

        {% if block.settings.featured_products.count > 0 %}
          <div class="ai-products-carousel-wrapper-{{ ai_gen_id }}">
            <div class="ai-products-carousel-{{ ai_gen_id }}" data-carousel>
              {% for product in block.settings.featured_products %}
                <a
                  href="{{ product.url }}"
                  class="ai-product-card-{{ ai_gen_id }}"
                >
                  <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 400 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="400"
                        height="400"
                        class="ai-product-image-{{ ai_gen_id }}"
                      >
                    {% else %}
                      <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-product-info-{{ ai_gen_id }}">
                    <h4 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h4>
                    <div class="ai-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                  </div>
                </a>
              {% endfor %}
            </div>

            {% if block.settings.featured_products.count > 1 %}
              <div class="ai-carousel-nav-{{ ai_gen_id }}">
                <button
                  class="ai-carousel-button-{{ ai_gen_id }}"
                  data-prev
                  aria-label="Previous products"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                </button>
                <button
                  class="ai-carousel-button-{{ ai_gen_id }}"
                  data-next
                  aria-label="Next products"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </button>
              </div>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-empty-products-{{ ai_gen_id }}">
            Add products to showcase the artist's gear
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</artist-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class ArtistShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');

        if (this.carousel && this.prevButton && this.nextButton) {
          this.setupCarousel();
        }
      }

      setupCarousel() {
        this.prevButton.addEventListener('click', () => {
          this.scroll(-1);
        });

        this.nextButton.addEventListener('click', () => {
          this.scroll(1);
        });

        this.carousel.addEventListener('scroll', () => {
          this.updateButtons();
        });

        this.updateButtons();
      }

      scroll(direction) {
        const scrollAmount = 216;
        this.carousel.scrollBy({
          left: direction * scrollAmount,
          behavior: 'smooth'
        });
      }

      updateButtons() {
        const isAtStart = this.carousel.scrollLeft <= 0;
        const isAtEnd = this.carousel.scrollLeft + this.carousel.clientWidth >= this.carousel.scrollWidth - 1;

        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }
    }

    customElements.define('artist-showcase-{{ ai_gen_id }}', ArtistShowcase{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Artist showcase",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Artist"
    },
    {
      "type": "image_picker",
      "id": "artist_image",
      "label": "Artist image"
    },
    {
      "type": "text",
      "id": "artist_name",
      "label": "Artist name",
      "default": "Featured Artist"
    },
    {
      "type": "richtext",
      "id": "artist_bio",
      "label": "Artist bio",
      "default": "<p>Discover the story and signature sound of this talented musician.</p>"
    },
    {
      "type": "range",
      "id": "artist_name_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Name size",
      "default": 32
    },
    {
      "type": "range",
      "id": "bio_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Bio size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Gear used by this artist"
    },
    {
      "type": "range",
      "id": "products_heading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 20
    },
    {
      "type": "product_list",
      "id": "featured_products",
      "label": "Featured products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Gap between columns",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Carousel buttons"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#ce0e2d"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button icon",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#a00b24"
    }
  ],
  "presets": [
    {
      "name": "Artist showcase"
    }
  ]
}
{% endschema %}

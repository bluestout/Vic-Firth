{% doc %}
  @prompt
    Session Gear Section Request
    Section Overview
    
    Add a section titled “Session Gear”
    
    The section should span the full available content width of the page
    
    Include a horizontal, scrollable product carousel
    
    Product Cards
    
    Each product card should include:
    
    Product image
    
    Product name
    
    Price
    
    “View product” or “Quick add” button
    
    Requirements:
    
    All product cards must be evenly sized and aligned
    
    Cards should feel clean, premium, and not cluttered
    
    Artist Filtering
    
    Include a row of artist filter buttons at the top (e.g. Tony, John, Pete)
    
    Do NOT include an “All Gear” / “All” filter option
    
    When an artist is selected:
    
    Only show products associated with that artist
    
    Each product should be manually assigned to an artist within the section settings
    
    Clearly indicate the active selected artist
    
    Carousel Behavior
    
    Display products in a single horizontal row
    
    On desktop:
    
    Show exactly 4 products at a time
    
    Do NOT display all products at once
    
    If more than 4 products exist:
    
    Allow users to scroll/slide horizontally to view more
    
    Include:
    
    Previous / Next navigation controls
    
    When switching artists:
    
    Reset the carousel scroll position to the beginning
    
    Ensure:
    
    Smooth horizontal movement
    
    No layout shifting or breaking
    
    Mobile Behavior
    
    Maintain a horizontal swipeable carousel
    
    Ensure smooth touch scrolling
    
    Keep product cards readable and properly sized
    
    Design & Branding
    
    Style should be:
    
    Clean
    
    Minimal
    
    Performance-focused
    
    Match Vic Firth brand styling:
    
    Black / white / light gray palette
    
    Strong typography
    
    Use the existing Vic Firth brand font already loaded in the theme
    
    Match typography used elsewhere on the site
    
    Maintain strong spacing and visual hierarchy
    
    Ensure the section feels like a branded gear showcase, not a default Shopify grid
    
    Functionality Requirements
    
    Filtering must happen:
    
    Instantly on click
    
    Without page reload
    
    Products should:
    
    Not reload
    
    Not break layout when filtering
    
    Important Constraints
    
    Scope all styles and functionality ONLY to this section
    
    Do NOT apply global styles to:
    
    buttons
    
    divs
    
    fonts
    
    product cards
    
    sliders
    
    Do NOT affect any other sections on the site
    
    Optional Enhancements
    
    Allow one product to appear under multiple artists
    
    Include a small label on cards like:
    
    “Used in session”
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-session-gear-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-session-gear-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-session-gear-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-session-gear-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px 0;
    letter-spacing: -0.02em;
  }

  .ai-session-gear-filters-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }} {
    padding: 10px 24px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 1px solid {{ block.settings.filter_border_color }};
    border-radius: {{ block.settings.filter_border_radius }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.filter_hover_bg_color }};
    color: {{ block.settings.filter_hover_text_color }};
    border-color: {{ block.settings.filter_hover_border_color }};
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_border_color }};
  }

  .ai-session-gear-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-top: 32px;
  }

  .ai-session-gear-carousel-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-session-gear-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-session-gear-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - (3 * {{ block.settings.card_gap }}px)) / 4);
    background-color: {{ block.settings.card_bg_color }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ai-session-gear-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-session-gear-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    background-color: #f8f8f9;
    overflow: hidden;
  }

  .ai-session-gear-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-session-gear-card-label-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.label_bg_color }};
    color: {{ block.settings.label_text_color }};
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-session-gear-card-content-{{ ai_gen_id }} {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-session-gear-card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 700;
    font-size: 16px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ai-session-gear-card-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 18px;
    color: {{ block.settings.card_price_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-session-gear-card-button-{{ ai_gen_id }} {
    margin-top: auto;
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 700;
    font-size: 14px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
  }

  .ai-session-gear-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-session-gear-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background-color: {{ block.settings.nav_bg_color }};
    border: 1px solid {{ block.settings.nav_border_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .ai-session-gear-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    border-color: {{ block.settings.nav_hover_border_color }};
  }

  .ai-session-gear-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-session-gear-nav-{{ ai_gen_id }}.prev {
    left: -24px;
  }

  .ai-session-gear-nav-{{ ai_gen_id }}.next {
    right: -24px;
  }

  .ai-session-gear-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-session-gear-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-session-gear-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - (2 * {{ block.settings.card_gap }}px)) / 3);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-session-gear-{{ ai_gen_id }} {
      padding: 40px 0;
    }

    .ai-session-gear-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
    }

    .ai-session-gear-carousel-{{ ai_gen_id }} {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .ai-session-gear-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-session-gear-track-{{ ai_gen_id }} {
      transition: none;
    }

    .ai-session-gear-card-{{ ai_gen_id }} {
      flex: 0 0 280px;
    }

    .ai-session-gear-nav-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<session-gear-{{ ai_gen_id }} class="ai-session-gear-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-session-gear-container-{{ ai_gen_id }}">
    <div class="ai-session-gear-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-session-gear-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      <div class="ai-session-gear-filters-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign artist_name_key = 'artist_' | append: i | append: '_name'
            assign artist_name = block.settings[artist_name_key]
          %}
          {% if artist_name != blank %}
            <button
              class="ai-session-gear-filter-btn-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-artist="{{ i }}"
            >
              {{ artist_name }}
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-session-gear-carousel-wrapper-{{ ai_gen_id }}">
      <button class="ai-session-gear-nav-{{ ai_gen_id }} prev" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-session-gear-carousel-{{ ai_gen_id }}">
        <div class="ai-session-gear-track-{{ ai_gen_id }}">
          {% for i in (1..20) %}
            {% liquid
              assign product_key = 'product_' | append: i
              assign artist_key = 'product_' | append: i | append: '_artist'
              assign product = block.settings[product_key]
              assign artist = block.settings[artist_key]
            %}
            {% if product != blank and artist != blank %}
              <div class="ai-session-gear-card-{{ ai_gen_id }}" data-artist="{{ artist }}" style="display: none;">
                <div class="ai-session-gear-card-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-session-gear-card-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% endif %}
                  {% if block.settings.show_label %}
                    <div class="ai-session-gear-card-label-{{ ai_gen_id }}">{{ block.settings.label_text }}</div>
                  {% endif %}
                </div>
                <div class="ai-session-gear-card-content-{{ ai_gen_id }}">
                  <h3 class="ai-session-gear-card-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-session-gear-card-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                  <a href="{{ product.url }}" class="ai-session-gear-card-button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <button class="ai-session-gear-nav-{{ ai_gen_id }} next" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <div class="ai-session-gear-empty-{{ ai_gen_id }}" style="display: none;">
      No products found for this artist.
    </div>
  </div>
</session-gear-{{ ai_gen_id }}>

<script>
  (function() {
    class SessionGear{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentArtist = '1';
        this.currentIndex = 0;
        this.cardsPerView = 4;
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-session-gear-filter-btn-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-session-gear-card-{{ ai_gen_id }}');
        this.track = this.querySelector('.ai-session-gear-track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-session-gear-nav-{{ ai_gen_id }}.prev');
        this.nextButton = this.querySelector('.ai-session-gear-nav-{{ ai_gen_id }}.next');
        this.emptyState = this.querySelector('.ai-session-gear-empty-{{ ai_gen_id }}');
        this.carousel = this.querySelector('.ai-session-gear-carousel-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.updateCardsPerView();
        this.filterProducts(this.currentArtist);

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.updateCarousel();
        });
      }

      setupEventListeners() {
        this.filterButtons.forEach(button => {
          button.addEventListener('click', () => {
            this.filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            this.currentArtist = button.dataset.artist;
            this.currentIndex = 0;
            this.filterProducts(this.currentArtist);
          });
        });

        this.prevButton.addEventListener('click', () => this.navigate(-1));
        this.nextButton.addEventListener('click', () => this.navigate(1));
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = 1;
        } else if (width <= 989) {
          this.cardsPerView = 3;
        } else {
          this.cardsPerView = 4;
        }
      }

      filterProducts(artistId) {
        let visibleCards = [];

        this.cards.forEach(card => {
          if (card.dataset.artist === artistId) {
            card.style.display = 'flex';
            visibleCards.push(card);
          } else {
            card.style.display = 'none';
          }
        });

        if (visibleCards.length === 0) {
          this.emptyState.style.display = 'block';
          this.carousel.style.display = 'none';
          this.prevButton.style.display = 'none';
          this.nextButton.style.display = 'none';
        } else {
          this.emptyState.style.display = 'none';
          this.carousel.style.display = 'block';
          if (window.innerWidth > 749) {
            this.prevButton.style.display = 'flex';
            this.nextButton.style.display = 'flex';
          }
        }

        this.visibleCards = visibleCards;
        this.updateCarousel();
      }

      navigate(direction) {
        const maxIndex = Math.max(0, this.visibleCards.length - this.cardsPerView);
        this.currentIndex = Math.max(0, Math.min(maxIndex, this.currentIndex + direction));
        this.updateCarousel();
      }

      updateCarousel() {
        if (!this.visibleCards || this.visibleCards.length === 0) return;

        const cardWidth = this.visibleCards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        const maxIndex = Math.max(0, this.visibleCards.length - this.cardsPerView);
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('session-gear-{{ ai_gen_id }}', SessionGear{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Create a “Session Gear” section that functions as a full-width product carousel.
    
    Layout:
    
    The section should span the full available content width of the page
    
    Display products in a single horizontal row
    
    Show exactly 4 products at a time on desktop
    
    Do not display all products at once
    
    Carousel behavior:
    
    Add horizontal sliding functionality so users can scroll through additional products
    
    Include clear previous and next navigation controls
    
    Ensure smooth horizontal movement when navigating
    
    On mobile, allow swipe gestures to scroll through products
    
    Filtering:
    
    Include artist filter buttons (for example: Tony, John, Pete)
    
    When an artist is selected, only show products associated with that artist
    
    Remove any “All Gear” or “See All” filter options
    
    Clearly indicate the active selected artist
    
    Product cards:
    
    Each product should include:
    
    product image
    
    product name
    
    price
    
    “View Product” button
    
    Ensure all product cards are evenly sized and aligned
    
    Design:
    
    Use the existing Vic Firth brand font already loaded in the theme
    
    Match typography and styling used across the site
    
    Keep the design clean, minimal, and premium
    
    Maintain strong spacing and alignment
    
    Ensure the section feels like a branded gear showcase, not a default Shopify grid
    
    Important:
    
    Scope all styles and functionality only to this section
    
    Do not apply global changes that affect other parts of the site
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-session-gear-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-session-gear-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-session-gear-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-session-gear-title-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 24px 0;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-session-gear-filters-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    justify-content: {{ block.settings.filter_alignment }};
    flex-wrap: wrap;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 1px solid {{ block.settings.filter_border_color }};
    border-radius: {{ block.settings.filter_radius }}px;
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.filter_hover_bg_color }};
    color: {{ block.settings.filter_hover_text_color }};
    border-color: {{ block.settings.filter_hover_border_color }};
  }

  .ai-session-gear-filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_border_color }};
  }

  .ai-session-gear-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-top: 40px;
  }

  .ai-session-gear-carousel-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-session-gear-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    transition: transform 0.4s ease;
    touch-action: pan-y;
  }

  .ai-session-gear-product-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.product_gap }}px * 3)) / 4);
    min-width: 0;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .ai-session-gear-product-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-session-gear-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .ai-session-gear-product-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    background-color: #f8f8f9;
    overflow: hidden;
  }

  .ai-session-gear-product-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-session-gear-product-info-{{ ai_gen_id }} {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-session-gear-product-title-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  .ai-session-gear-product-price-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: 18px;
    font-weight: 700;
    color: {{ block.settings.product_price_color }};
    margin: 0 0 16px 0;
  }

  .ai-session-gear-product-btn-{{ ai_gen_id }} {
    margin-top: auto;
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: block;
  }

  .ai-session-gear-product-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-session-gear-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background-color: {{ block.settings.nav_bg_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-session-gear-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-session-gear-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-session-gear-nav-prev-{{ ai_gen_id }} {
    left: -24px;
  }

  .ai-session-gear-nav-next-{{ ai_gen_id }} {
    right: -24px;
  }

  .ai-session-gear-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-session-gear-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-session-gear-product-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.product_gap }}px * 1)) / 2);
    }

    .ai-session-gear-nav-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-session-gear-nav-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-session-gear-{{ ai_gen_id }} {
      padding: 40px 0;
    }

    .ai-session-gear-product-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-session-gear-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<session-gear-carousel-{{ ai_gen_id }} class="ai-session-gear-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-session-gear-container-{{ ai_gen_id }}">
    <div class="ai-session-gear-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-session-gear-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      <div class="ai-session-gear-filters-{{ ai_gen_id }}">
        {% if block.settings.artist_1_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }} active"
            data-artist="{{ block.settings.artist_1_tag }}"
          >
            {{ block.settings.artist_1_name }}
          </button>
        {% endif %}

        {% if block.settings.artist_2_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-artist="{{ block.settings.artist_2_tag }}"
          >
            {{ block.settings.artist_2_name }}
          </button>
        {% endif %}

        {% if block.settings.artist_3_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-artist="{{ block.settings.artist_3_tag }}"
          >
            {{ block.settings.artist_3_name }}
          </button>
        {% endif %}

        {% if block.settings.artist_4_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-artist="{{ block.settings.artist_4_tag }}"
          >
            {{ block.settings.artist_4_name }}
          </button>
        {% endif %}

        {% if block.settings.artist_5_name != blank %}
          <button
            class="ai-session-gear-filter-btn-{{ ai_gen_id }}"
            data-artist="{{ block.settings.artist_5_tag }}"
          >
            {{ block.settings.artist_5_name }}
          </button>
        {% endif %}
      </div>
    </div>

    {% if block.settings.product_collection != blank %}
      <div class="ai-session-gear-carousel-wrapper-{{ ai_gen_id }}">
        <button
          class="ai-session-gear-nav-{{ ai_gen_id }} ai-session-gear-nav-prev-{{ ai_gen_id }}"
          aria-label="Previous products"
        >
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="ai-session-gear-carousel-{{ ai_gen_id }}">
          <div class="ai-session-gear-track-{{ ai_gen_id }}">
            {% for product in block.settings.product_collection.products %}
              {% assign artist_tags = '' %}
              {% for tag in product.tags %}
                {% assign tag_lower = tag | downcase %}
                {% if tag_lower contains 'artist:' or tag_lower contains 'artist-' %}
                  {% assign artist_tags = artist_tags | append: tag | append: ',' %}
                {% endif %}
              {% endfor %}

              <div
                class="ai-session-gear-product-{{ ai_gen_id }}"
                data-artist-tags="{{ artist_tags }}"
              >
                <div class="ai-session-gear-product-card-{{ ai_gen_id }}">
                  <div class="ai-session-gear-product-image-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      <div class="ai-session-gear-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="ai-session-gear-product-info-{{ ai_gen_id }}">
                    <h3 class="ai-session-gear-product-title-{{ ai_gen_id }}">
                      {{ product.title }}
                    </h3>

                    <div class="ai-session-gear-product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </div>

                    <a
                      href="{{ product.url }}"
                      class="ai-session-gear-product-btn-{{ ai_gen_id }}"
                    >
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <button
          class="ai-session-gear-nav-{{ ai_gen_id }} ai-session-gear-nav-next-{{ ai_gen_id }}"
          aria-label="Next products"
        >
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% else %}
      <div class="ai-session-gear-empty-{{ ai_gen_id }}">
        Select a product collection to display session gear
      </div>
    {% endif %}
  </div>
</session-gear-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class SessionGearCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerView = 4;
        this.currentArtist = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-session-gear-track-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-session-gear-nav-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-session-gear-nav-next-{{ ai_gen_id }}');
        this.filterBtns = this.querySelectorAll('.ai-session-gear-filter-btn-{{ ai_gen_id }}');
        this.products = this.querySelectorAll('.ai-session-gear-product-{{ ai_gen_id }}');

        if (!this.track) return;

        this.setupFilters();
        this.setupCarousel();
        this.setupTouchEvents();
        this.updateItemsPerView();

        window.addEventListener('resize', () => this.updateItemsPerView());
      }

      setupFilters() {
        this.filterBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            this.filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const artistTag = btn.getAttribute('data-artist');
            this.currentArtist = artistTag;
            this.filterProducts(artistTag);
            this.currentIndex = 0;
            this.updateCarousel();
          });
        });

        if (this.filterBtns.length > 0) {
          const firstArtist = this.filterBtns[0].getAttribute('data-artist');
          this.currentArtist = firstArtist;
          this.filterProducts(firstArtist);
        }
      }

      filterProducts(artistTag) {
        this.products.forEach(product => {
          const productTags = product.getAttribute('data-artist-tags').toLowerCase();
          const artistTagLower = artistTag.toLowerCase();

          if (productTags.includes(artistTagLower)) {
            product.classList.remove('hidden');
          } else {
            product.classList.add('hidden');
          }
        });

        this.visibleProducts = Array.from(this.products).filter(p => !p.classList.contains('hidden'));
        this.updateNavButtons();
      }

      setupCarousel() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }

        this.visibleProducts = Array.from(this.products).filter(p => !p.classList.contains('hidden'));
        this.updateNavButtons();
      }

      setupTouchEvents() {
        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;

          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.next();
            } else {
              this.prev();
            }
          }
        });
      }

      updateItemsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.itemsPerView = 1;
        } else if (width <= 989) {
          this.itemsPerView = 2;
        } else {
          this.itemsPerView = 4;
        }
        this.updateCarousel();
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.visibleProducts.length - this.itemsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        if (!this.visibleProducts || this.visibleProducts.length === 0) return;

        const firstVisibleProduct = this.visibleProducts[0];
        if (!firstVisibleProduct) return;

        const productWidth = firstVisibleProduct.offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const offset = -(this.currentIndex * (productWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;
        this.updateNavButtons();
      }

      updateNavButtons() {
        if (!this.prevBtn || !this.nextBtn || !this.visibleProducts) return;

        const maxIndex = Math.max(0, this.visibleProducts.length - this.itemsPerView);

        this.prevBtn.disabled = this.currentIndex === 0;
        this.nextBtn.disabled = this.currentIndex >= maxIndex || this.visibleProducts.length <= this.itemsPerView;
      }
    }

    customElements.define('session-gear-carousel-{{ ai_gen_id }}', SessionGearCarousel{{ ai_gen_id }});
  })();
</script>


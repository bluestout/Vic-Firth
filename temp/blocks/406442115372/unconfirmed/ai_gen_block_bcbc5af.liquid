{% doc %}
  @prompt
    Create a rich text expandable block with the following features: 1) A customizable title field displayed above the content. 2) On mobile, the rich text content is truncated at a height threshold with a "Read more" button that expands it, and a "Read less" button to collapse it. 3) The Read more/Read less button should be full width on mobile. 4) On desktop, always show full content with no button.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-expandable-text-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-expandable-text__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
  }

  .ai-expandable-text__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    font-weight: 600;
  }

  .ai-expandable-text__content-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-expandable-text__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    overflow: hidden;
  }

  .ai-expandable-text__content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-expandable-text__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-expandable-text__content-{{ ai_gen_id }} h1,
  .ai-expandable-text__content-{{ ai_gen_id }} h2,
  .ai-expandable-text__content-{{ ai_gen_id }} h3,
  .ai-expandable-text__content-{{ ai_gen_id }} h4,
  .ai-expandable-text__content-{{ ai_gen_id }} h5,
  .ai-expandable-text__content-{{ ai_gen_id }} h6 {
    margin: 1em 0 0.5em 0;
  }

  .ai-expandable-text__content-{{ ai_gen_id }} ul,
  .ai-expandable-text__content-{{ ai_gen_id }} ol {
    margin: 0 0 1em 0;
    padding-left: 1.5em;
  }

  .ai-expandable-text__fade-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, {{ block.settings.fade_color }});
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .ai-expandable-text__fade-{{ ai_gen_id }}.hidden {
    opacity: 0;
  }

  .ai-expandable-text__button-{{ ai_gen_id }} {
    width: 100%;
    margin-top: {{ block.settings.button_spacing }}px;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: none;
  }

  .ai-expandable-text__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-expandable-text__content-{{ ai_gen_id }}.truncated {
      max-height: {{ block.settings.mobile_max_height }}px;
    }

    .ai-expandable-text__button-{{ ai_gen_id }} {
      display: block;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-expandable-text__fade-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<expandable-text-{{ ai_gen_id }} class="ai-expandable-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-expandable-text__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-expandable-text__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-expandable-text__content-wrapper-{{ ai_gen_id }}">
      <div class="ai-expandable-text__content-{{ ai_gen_id }} truncated" data-content>
        {% if block.settings.content != blank %}
          {{ block.settings.content }}
        {% else %}
          <p>Add your rich text content here. You can include paragraphs, headings, lists, and more.</p>
        {% endif %}
      </div>
      <div class="ai-expandable-text__fade-{{ ai_gen_id }}" data-fade></div>
    </div>

    <button class="ai-expandable-text__button-{{ ai_gen_id }}" data-toggle aria-expanded="false">
      <span data-read-more>{{ block.settings.read_more_text }}</span>
      <span data-read-less style="display: none;">{{ block.settings.read_less_text }}</span>
    </button>
  </div>
</expandable-text-{{ ai_gen_id }}>

<script>
  (function() {
    class ExpandableText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.content = null;
        this.button = null;
        this.fade = null;
        this.readMoreText = null;
        this.readLessText = null;
        this.isExpanded = false;
        this.isMobile = false;
      }

      connectedCallback() {
        this.content = this.querySelector('[data-content]');
        this.button = this.querySelector('[data-toggle]');
        this.fade = this.querySelector('[data-fade]');
        this.readMoreText = this.querySelector('[data-read-more]');
        this.readLessText = this.querySelector('[data-read-less]');

        if (!this.content || !this.button) return;

        this.checkIfMobile();
        this.setupEventListeners();
        this.checkContentHeight();

        window.addEventListener('resize', this.handleResize.bind(this));
      }

      disconnectedCallback() {
        window.removeEventListener('resize', this.handleResize.bind(this));
      }

      checkIfMobile() {
        this.isMobile = window.innerWidth < 750;
      }

      setupEventListeners() {
        this.button.addEventListener('click', this.toggleContent.bind(this));
      }

      checkContentHeight() {
        if (!this.isMobile) {
          this.content.classList.remove('truncated');
          this.fade.classList.add('hidden');
          return;
        }

        const maxHeight = parseInt('{{ block.settings.mobile_max_height }}');
        const actualHeight = this.content.scrollHeight;

        if (actualHeight <= maxHeight) {
          this.button.style.display = 'none';
          this.fade.classList.add('hidden');
        } else {
          this.button.style.display = 'block';
          if (!this.isExpanded) {
            this.fade.classList.remove('hidden');
          }
        }
      }

      toggleContent() {
        this.isExpanded = !this.isExpanded;

        if (this.isExpanded) {
          this.content.classList.remove('truncated');
          this.fade.classList.add('hidden');
          this.readMoreText.style.display = 'none';
          this.readLessText.style.display = 'inline';
          this.button.setAttribute('aria-expanded', 'true');
        } else {
          this.content.classList.add('truncated');
          this.fade.classList.remove('hidden');
          this.readMoreText.style.display = 'inline';
          this.readLessText.style.display = 'none';
          this.button.setAttribute('aria-expanded', 'false');
        }
      }

      handleResize() {
        const wasMobile = this.isMobile;
        this.checkIfMobile();

        if (wasMobile !== this.isMobile) {
          this.isExpanded = false;
          this.content.classList.add('truncated');
          this.readMoreText.style.display = 'inline';
          this.readLessText.style.display = 'none';
          this.button.setAttribute('aria-expanded', 'false');
          this.checkContentHeight();
        }
      }
    }

    customElements.define('expandable-text-{{ ai_gen_id }}', ExpandableText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Expandable rich text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "About This Product"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Rich text content",
      "default": "<p>Add your detailed content here. This text will be expandable on mobile devices when it exceeds the height threshold, but will always display in full on desktop.</p>"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile behavior"
    },
    {
      "type": "range",
      "id": "mobile_max_height",
      "label": "Mobile collapsed height",
      "min": 100,
      "max": 500,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "inline_richtext",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read more"
    },
    {
      "type": "inline_richtext",
      "id": "read_less_text",
      "label": "Read less text",
      "default": "Read less"
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "fade_color",
      "label": "Fade gradient color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_spacing",
      "label": "Button top spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Container padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Expandable rich text"
    }
  ]
}
{% endschema %}

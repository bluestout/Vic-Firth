{% doc %}
  @prompt
    Edit the current rich text section so that on mobile devices, the content is truncated at a certain height threshold. Add a "Read more" button that expands the full content when tapped. When the content is fully expanded, show a "Read less" button that collapses it back. This expand/collapse functionality should only apply on mobile — desktop should always show the full content without any truncation or buttons.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-rich-text-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.6;
  }

  .ai-rich-text-content-{{ ai_gen_id }} p {
    margin-bottom: 1em;
  }

  .ai-rich-text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-rich-text-toggle-{{ ai_gen_id }} {
    display: none;
    margin-top: 16px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-rich-text-toggle-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-content-{{ ai_gen_id }} {
      max-height: {{ block.settings.mobile_max_height }}px;
      overflow: hidden;
      position: relative;
      transition: max-height 0.4s ease;
    }

    .ai-rich-text-content-{{ ai_gen_id }}.expanded {
      max-height: none;
    }

    .ai-rich-text-content-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: linear-gradient(to bottom, transparent, {{ block.settings.background_color }});
      pointer-events: none;
      opacity: 1;
      transition: opacity 0.3s ease;
    }

    .ai-rich-text-content-{{ ai_gen_id }}.expanded::after {
      opacity: 0;
    }

    .ai-rich-text-toggle-{{ ai_gen_id }} {
      display: inline-block;
    }

    .ai-rich-text-toggle-{{ ai_gen_id }}.hidden {
      display: none;
    }
  }
{% endstyle %}

<rich-text-expandable-{{ ai_gen_id }}
  class="ai-rich-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-rich-text-content-{{ ai_gen_id }}">
    {{ block.settings.rich_text }}
  </div>
  <button
    class="ai-rich-text-toggle-{{ ai_gen_id }}"
    aria-expanded="false"
  >
    {{ block.settings.read_more_text }}
  </button>
</rich-text-expandable-{{ ai_gen_id }}>

<script>
  (function() {
    class RichTextExpandable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.content = null;
        this.button = null;
        this.isExpanded = false;
        this.readMoreText = '{{ block.settings.read_more_text }}';
        this.readLessText = '{{ block.settings.read_less_text }}';
        this.mobileMaxHeight = {{ block.settings.mobile_max_height }};
      }

      connectedCallback() {
        this.content = this.querySelector('.ai-rich-text-content-{{ ai_gen_id }}');
        this.button = this.querySelector('.ai-rich-text-toggle-{{ ai_gen_id }}');

        if (!this.content || !this.button) return;

        this.checkIfTruncated();
        this.button.addEventListener('click', () => this.toggleContent());

        window.addEventListener('resize', () => this.handleResize());
      }

      checkIfTruncated() {
        if (window.innerWidth > 749) {
          this.button.classList.add('hidden');
          return;
        }

        if (this.content.scrollHeight > this.mobileMaxHeight) {
          this.button.classList.remove('hidden');
        } else {
          this.button.classList.add('hidden');
        }
      }

      toggleContent() {
        this.isExpanded = !this.isExpanded;

        if (this.isExpanded) {
          this.content.classList.add('expanded');
          this.button.textContent = this.readLessText;
          this.button.setAttribute('aria-expanded', 'true');
        } else {
          this.content.classList.remove('expanded');
          this.button.textContent = this.readMoreText;
          this.button.setAttribute('aria-expanded', 'false');
        }
      }

      handleResize() {
        if (window.innerWidth > 749) {
          this.content.classList.remove('expanded');
          this.button.classList.add('hidden');
          this.isExpanded = false;
          this.button.textContent = this.readMoreText;
          this.button.setAttribute('aria-expanded', 'false');
        } else {
          this.checkIfTruncated();
        }
      }
    }

    customElements.define('rich-text-expandable-{{ ai_gen_id }}', RichTextExpandable{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Rich text expandable",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "rich_text",
      "label": "Text",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store. Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store. Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "range",
      "id": "mobile_max_height",
      "label": "Collapsed height",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more button text",
      "default": "Read more"
    },
    {
      "type": "text",
      "id": "read_less_text",
      "label": "Read less button text",
      "default": "Read less"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#ce0e2d"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#a00b24"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Rich text expandable"
    }
  ]
}
{% endschema %}

{% doc %}
  @prompt
    Create a "Read more accordion" block with separate collapsed height settings for mobile and desktop. The block should have: a heading field, a content/text field, separate collapsed height range settings for mobile and desktop, a "Read More" / "Read Less" toggle button with customizable text and color settings, and a desktop width percent setting. The accordion should expand/collapse smoothly with JavaScript. On desktop, if the collapsed height is set high enough to show all content, the button should be hidden automatically.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-read-more-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-read-more-accordion__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}.collapsed {
    max-height: {{ block.settings.collapsed_height_mobile }}px;
  }

  .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}.collapsed::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, {{ block.settings.fade_color }});
    pointer-events: none;
  }

  .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}.expanded {
    max-height: none;
  }

  .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}.expanded::after {
    display: none;
  }

  .ai-read-more-accordion__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.content_color }};
    line-height: 1.6;
  }

  .ai-read-more-accordion__button-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-read-more-accordion__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-read-more-accordion__button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}.collapsed {
      max-height: {{ block.settings.collapsed_height_desktop }}px;
    }
  }
{% endstyle %}

<read-more-accordion-{{ ai_gen_id }}
  class="ai-read-more-accordion-{{ ai_gen_id }}"
  data-collapsed-height-mobile="{{ block.settings.collapsed_height_mobile }}"
  data-collapsed-height-desktop="{{ block.settings.collapsed_height_desktop }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-read-more-accordion__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-read-more-accordion__content-wrapper-{{ ai_gen_id }} collapsed">
    <div class="ai-read-more-accordion__content-{{ ai_gen_id }}">
      {{ block.settings.content }}
    </div>
  </div>

  <button
    class="ai-read-more-accordion__button-{{ ai_gen_id }}"
    aria-expanded="false"
  >
    {{ block.settings.read_more_text }}
  </button>
</read-more-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class ReadMoreAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.button = this.querySelector('.ai-read-more-accordion__button-{{ ai_gen_id }}');
        this.contentWrapper = this.querySelector('.ai-read-more-accordion__content-wrapper-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-read-more-accordion__content-{{ ai_gen_id }}');
        this.isExpanded = false;
        this.readMoreText = '{{ block.settings.read_more_text }}';
        this.readLessText = '{{ block.settings.read_less_text }}';
        this.collapsedHeightMobile = parseInt(this.dataset.collapsedHeightMobile);
        this.collapsedHeightDesktop = parseInt(this.dataset.collapsedHeightDesktop);
      }

      connectedCallback() {
        this.checkContentHeight();
        this.button.addEventListener('click', () => this.toggleContent());
        window.addEventListener('resize', () => this.checkContentHeight());
      }

      checkContentHeight() {
        const contentHeight = this.content.scrollHeight;
        const isDesktop = window.innerWidth >= 750;
        const collapsedHeight = isDesktop ? this.collapsedHeightDesktop : this.collapsedHeightMobile;

        if (contentHeight <= collapsedHeight) {
          this.button.classList.add('hidden');
          this.contentWrapper.classList.remove('collapsed');
          this.contentWrapper.classList.add('expanded');
        } else {
          this.button.classList.remove('hidden');
          if (!this.isExpanded) {
            this.contentWrapper.classList.add('collapsed');
            this.contentWrapper.classList.remove('expanded');
          }
        }
      }

      toggleContent() {
        this.isExpanded = !this.isExpanded;

        if (this.isExpanded) {
          this.contentWrapper.classList.remove('collapsed');
          this.contentWrapper.classList.add('expanded');
          this.button.textContent = this.readLessText;
          this.button.setAttribute('aria-expanded', 'true');
        } else {
          this.contentWrapper.classList.add('collapsed');
          this.contentWrapper.classList.remove('expanded');
          this.button.textContent = this.readMoreText;
          this.button.setAttribute('aria-expanded', 'false');
        }
      }
    }

    customElements.define('read-more-accordion-{{ ai_gen_id }}', ReadMoreAccordion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Read more accordion",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About this product"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Add your detailed content here. This text will be collapsed initially and can be expanded by clicking the read more button. You can include multiple paragraphs, lists, and other formatted content to provide comprehensive information to your customers.</p>"
    },
    {
      "type": "header",
      "content": "Collapsed height"
    },
    {
      "type": "range",
      "id": "collapsed_height_mobile",
      "label": "Mobile collapsed height",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "collapsed_height_desktop",
      "label": "Desktop collapsed height",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read more"
    },
    {
      "type": "text",
      "id": "read_less_text",
      "label": "Read less text",
      "default": "Read less"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#ce0e2d"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#a00b24"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "Content size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "fade_color",
      "label": "Fade gradient color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Read more accordion"
    }
  ]
}
{% endschema %}

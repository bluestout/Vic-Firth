{% doc %}
  @prompt
    Create a Factory Sessions section that displays multiple artists with their performance videos. Each artist should have:
    - Artist name and image
    - A label (e.g., "2 performances")
    - Two YouTube video embeds that play inline
    - Video titles below each video
    
    The section should support up to 6 artists with the ability to enable/disable each one. Videos should be embedded using YouTube's iframe embed code and accept both youtube.com/watch and youtu.be URL formats. Include settings for customizing colors, spacing, typography, and layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-factory-sessions-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-factory-sessions-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-factory-sessions-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-factory-sessions-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-factory-sessions-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-factory-sessions-artist-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
  }

  .ai-factory-sessions-artist-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.artist_header_gap }}px;
    margin-bottom: {{ block.settings.artist_header_spacing }}px;
  }

  .ai-factory-sessions-artist-image-{{ ai_gen_id }} {
    width: {{ block.settings.artist_image_size }}px;
    height: {{ block.settings.artist_image_size }}px;
    border-radius: {{ block.settings.artist_image_radius }}px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-factory-sessions-artist-image-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.artist_image_size }}px;
    height: {{ block.settings.artist_image_size }}px;
    border-radius: {{ block.settings.artist_image_radius }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-factory-sessions-artist-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-factory-sessions-artist-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-factory-sessions-artist-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.artist_name_size }}px;
    color: {{ block.settings.artist_name_color }};
    margin: 0 0 4px 0;
    font-weight: 600;
  }

  .ai-factory-sessions-artist-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.artist_label_size }}px;
    color: {{ block.settings.artist_label_color }};
    margin: 0;
  }

  .ai-factory-sessions-videos-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.video_spacing }}px;
  }

  .ai-factory-sessions-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    background-color: #000000;
  }

  .ai-factory-sessions-video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .ai-factory-sessions-video-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.video_title_size }}px;
    color: {{ block.settings.video_title_color }};
    margin: {{ block.settings.video_title_spacing }}px 0 0 0;
  }

  .ai-factory-sessions-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  @media screen and (max-width: 989px) {
    .ai-factory-sessions-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-factory-sessions-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-factory-sessions-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-factory-sessions-artist-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.artist_name_size }}px * 0.9);
    }
  }
{% endstyle %}

<factory-sessions-{{ ai_gen_id }} class="ai-factory-sessions-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-factory-sessions-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <div class="ai-factory-sessions-header-{{ ai_gen_id }}">
        <h2 class="ai-factory-sessions-title-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
      </div>
    {% endif %}

    {% liquid
      assign enabled_artists = 0
      for i in (1..6)
        assign enabled_key = 'artist_' | append: i | append: '_enabled'
        if block.settings[enabled_key]
          assign enabled_artists = enabled_artists | plus: 1
        endif
      endfor
    %}

    {% if enabled_artists > 0 %}
      <div class="ai-factory-sessions-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign enabled_key = 'artist_' | append: i | append: '_enabled'
            assign name_key = 'artist_' | append: i | append: '_name'
            assign image_key = 'artist_' | append: i | append: '_image'
            assign label_key = 'artist_' | append: i | append: '_label'
            assign video1_url_key = 'artist_' | append: i | append: '_video1_url'
            assign video1_title_key = 'artist_' | append: i | append: '_video1_title'
            assign video2_url_key = 'artist_' | append: i | append: '_video2_url'
            assign video2_title_key = 'artist_' | append: i | append: '_video2_title'

            assign is_enabled = block.settings[enabled_key]
            assign artist_name = block.settings[name_key]
            assign artist_image = block.settings[image_key]
            assign artist_label = block.settings[label_key]
            assign video1_url = block.settings[video1_url_key]
            assign video1_title = block.settings[video1_title_key]
            assign video2_url = block.settings[video2_url_key]
            assign video2_title = block.settings[video2_title_key]
          %}

          {% if is_enabled %}
            <div class="ai-factory-sessions-artist-{{ ai_gen_id }}">
              <div class="ai-factory-sessions-artist-header-{{ ai_gen_id }}">
                {% if artist_image %}
                  <img
                    src="{{ artist_image | image_url: width: 200 }}"
                    alt="{{ artist_name | escape }}"
                    class="ai-factory-sessions-artist-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {% else %}
                  <div class="ai-factory-sessions-artist-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                <div class="ai-factory-sessions-artist-info-{{ ai_gen_id }}">
                  {% if artist_name != blank %}
                    <h3 class="ai-factory-sessions-artist-name-{{ ai_gen_id }}">{{ artist_name }}</h3>
                  {% endif %}
                  {% if artist_label != blank %}
                    <p class="ai-factory-sessions-artist-label-{{ ai_gen_id }}">{{ artist_label }}</p>
                  {% endif %}
                </div>
              </div>

              <div class="ai-factory-sessions-videos-{{ ai_gen_id }}">
                {% if video1_url != blank %}
                  <div>
                    <div class="ai-factory-sessions-video-wrapper-{{ ai_gen_id }}" data-video-url="{{ video1_url }}"></div>
                    {% if video1_title != blank %}
                      <p class="ai-factory-sessions-video-title-{{ ai_gen_id }}">{{ video1_title }}</p>
                    {% endif %}
                  </div>
                {% endif %}

                {% if video2_url != blank %}
                  <div>
                    <div class="ai-factory-sessions-video-wrapper-{{ ai_gen_id }}" data-video-url="{{ video2_url }}"></div>
                    {% if video2_title != blank %}
                      <p class="ai-factory-sessions-video-title-{{ ai_gen_id }}">{{ video2_title }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-factory-sessions-empty-state-{{ ai_gen_id }}">
        <p>Enable at least one artist to display Factory Sessions</p>
      </div>
    {% endif %}
  </div>
</factory-sessions-{{ ai_gen_id }}>

<script>
  (function() {
    class FactorySessions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeVideos();
      }

      initializeVideos() {
        const videoWrappers = this.querySelectorAll('.ai-factory-sessions-video-wrapper-{{ ai_gen_id }}');
        
        videoWrappers.forEach((wrapper) => {
          const videoUrl = wrapper.getAttribute('data-video-url');
          if (!videoUrl) return;

          const videoId = this.extractVideoId(videoUrl);
          if (videoId) {
            const iframe = document.createElement('iframe');
            iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0`;
            iframe.setAttribute('frameborder', '0');
            iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
            iframe.setAttribute('allowfullscreen', '');
            iframe.setAttribute('title', 'YouTube video player');
            wrapper.appendChild(iframe);
          }
        });
      }

      extractVideoId(url) {
        if (!url) return null;

        let videoId = null;

        if (url.includes('youtube.com/watch')) {
          const urlParams = new URLSearchParams(url.split('?')[1]);
          videoId = urlParams.get('v');
        } else if (url.includes('youtu.be/')) {
          const parts = url.split('youtu.be/');
          if (parts[1]) {
            videoId = parts[1].split('?')[0].split('&')[0];
          }
        } else if (url.includes('youtube.com/embed/')) {
          const parts = url.split('youtube.com/embed/');
          if (parts[1]) {
            videoId = parts[1].split('?')[0].split('&')[0];
          }
        }

        return videoId;
      }
    }

    customElements.define('factory-sessions-{{ ai_gen_id }}', FactorySessions{{ ai_gen_id }});
  })();
</script>


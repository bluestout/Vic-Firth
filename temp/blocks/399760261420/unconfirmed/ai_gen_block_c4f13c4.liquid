{% doc %}
  @prompt
    Create a "Factory Sessions" video showcase block that is exactly like the existing ai_gen_block_740c4d3 block on the /pages/factory-sessions page, but with the addition of a thumbnail image picker for each video. The block should include: up to 5 artists, each with up to 3 video performances. For each video, there should be settings for: a video upload field, a YouTube link field, a title field, a subtitle field, and a NEW thumbnail image picker field. The thumbnail should display as a preview image over the video player before the user clicks play. Keep all existing styling, layout, and functionality identical to the current block — just add the thumbnail feature.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-factory-sessions-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-factory-sessions-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-factory-sessions-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-factory-sessions-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-factory-sessions-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-factory-sessions-artists-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .ai-factory-sessions-artist-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-factory-sessions-artist-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.artist_name_size }}px;
    color: {{ block.settings.artist_name_color }};
    margin: 0;
    font-weight: 600;
    text-align: center;
  }

  .ai-factory-sessions-videos-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .ai-factory-sessions-video-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-factory-sessions-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #000000;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-factory-sessions-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-factory-sessions-thumbnail-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-factory-sessions-thumbnail-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-factory-sessions-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background-color: {{ block.settings.play_button_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease, background-color 0.3s ease;
    pointer-events: none;
  }

  .ai-factory-sessions-thumbnail-{{ ai_gen_id }}:hover + .ai-factory-sessions-play-button-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1.1);
    background-color: {{ block.settings.play_button_hover_color }};
  }

  .ai-factory-sessions-play-icon-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-left: 24px solid {{ block.settings.play_icon_color }};
    border-top: 16px solid transparent;
    border-bottom: 16px solid transparent;
    margin-left: 6px;
  }

  .ai-factory-sessions-video-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-factory-sessions-video-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.video_title_size }}px;
    color: {{ block.settings.video_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-factory-sessions-video-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.video_subtitle_size }}px;
    color: {{ block.settings.video_subtitle_color }};
    margin: 0;
  }

  .ai-factory-sessions-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-factory-sessions-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-factory-sessions-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-factory-sessions-videos-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-factory-sessions-play-button-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-factory-sessions-play-icon-{{ ai_gen_id }} {
      border-left-width: 18px;
      border-top-width: 12px;
      border-bottom-width: 12px;
      margin-left: 4px;
    }
  }
{% endstyle %}

<factory-sessions-{{ ai_gen_id }} class="ai-factory-sessions-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-factory-sessions-container-{{ ai_gen_id }}">
    {% if block.settings.main_title != blank or block.settings.main_subtitle != blank %}
      <div class="ai-factory-sessions-header-{{ ai_gen_id }}">
        {% if block.settings.main_title != blank %}
          <h2 class="ai-factory-sessions-title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
        {% endif %}
        {% if block.settings.main_subtitle != blank %}
          <p class="ai-factory-sessions-subtitle-{{ ai_gen_id }}">{{ block.settings.main_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-factory-sessions-artists-{{ ai_gen_id }}">
      {% for artist_num in (1..5) %}
        {% liquid
          assign artist_enabled_key = 'artist_' | append: artist_num | append: '_enabled'
          assign artist_name_key = 'artist_' | append: artist_num | append: '_name'
          
          assign artist_enabled = block.settings[artist_enabled_key]
          assign artist_name = block.settings[artist_name_key]
        %}

        {% if artist_enabled %}
          <div class="ai-factory-sessions-artist-{{ ai_gen_id }}">
            {% if artist_name != blank %}
              <h3 class="ai-factory-sessions-artist-name-{{ ai_gen_id }}">{{ artist_name }}</h3>
            {% endif %}

            <div class="ai-factory-sessions-videos-{{ ai_gen_id }}">
              {% for video_num in (1..3) %}
                {% liquid
                  assign video_enabled_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_enabled'
                  assign video_file_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_file'
                  assign youtube_link_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_youtube'
                  assign video_title_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_title'
                  assign video_subtitle_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_subtitle'
                  assign thumbnail_key = 'artist_' | append: artist_num | append: '_video_' | append: video_num | append: '_thumbnail'
                  
                  assign video_enabled = block.settings[video_enabled_key]
                  assign video_file = block.settings[video_file_key]
                  assign youtube_link = block.settings[youtube_link_key]
                  assign video_title = block.settings[video_title_key]
                  assign video_subtitle = block.settings[video_subtitle_key]
                  assign thumbnail = block.settings[thumbnail_key]
                  
                  assign video_id = ai_gen_id | append: '-artist-' | append: artist_num | append: '-video-' | append: video_num
                %}

                {% if video_enabled %}
                  <div class="ai-factory-sessions-video-item-{{ ai_gen_id }}">
                    <div class="ai-factory-sessions-video-wrapper-{{ ai_gen_id }}">
                      {% if video_file != blank %}
                        <video
                          class="ai-factory-sessions-video-{{ ai_gen_id }}"
                          id="{{ video_id }}"
                          controls
                          preload="metadata"
                        >
                          <source src="{{ video_file }}" type="video/mp4">
                        </video>
                        {% if thumbnail != blank %}
                          <img
                            src="{{ thumbnail | image_url: width: 800 }}"
                            alt="{{ video_title | escape }}"
                            class="ai-factory-sessions-thumbnail-{{ ai_gen_id }}"
                            data-video-id="{{ video_id }}"
                            loading="lazy"
                          >
                          <div class="ai-factory-sessions-play-button-{{ ai_gen_id }}">
                            <div class="ai-factory-sessions-play-icon-{{ ai_gen_id }}"></div>
                          </div>
                        {% endif %}
                      {% elsif youtube_link != blank %}
                        {% assign youtube_id = youtube_link | split: 'v=' | last | split: '&' | first %}
                        {% if youtube_link contains 'youtu.be' %}
                          {% assign youtube_id = youtube_link | split: 'youtu.be/' | last | split: '?' | first %}
                        {% endif %}
                        <iframe
                          class="ai-factory-sessions-video-{{ ai_gen_id }}"
                          id="{{ video_id }}"
                          src="https://www.youtube.com/embed/{{ youtube_id }}"
                          frameborder="0"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen
                        ></iframe>
                        {% if thumbnail != blank %}
                          <img
                            src="{{ thumbnail | image_url: width: 800 }}"
                            alt="{{ video_title | escape }}"
                            class="ai-factory-sessions-thumbnail-{{ ai_gen_id }}"
                            data-video-id="{{ video_id }}"
                            data-youtube-id="{{ youtube_id }}"
                            loading="lazy"
                          >
                          <div class="ai-factory-sessions-play-button-{{ ai_gen_id }}">
                            <div class="ai-factory-sessions-play-icon-{{ ai_gen_id }}"></div>
                          </div>
                        {% endif %}
                      {% else %}
                        <div class="ai-factory-sessions-placeholder-{{ ai_gen_id }}">
                          {{ 'image' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>

                    {% if video_title != blank or video_subtitle != blank %}
                      <div class="ai-factory-sessions-video-info-{{ ai_gen_id }}">
                        {% if video_title != blank %}
                          <h4 class="ai-factory-sessions-video-title-{{ ai_gen_id }}">{{ video_title }}</h4>
                        {% endif %}
                        {% if video_subtitle != blank %}
                          <p class="ai-factory-sessions-video-subtitle-{{ ai_gen_id }}">{{ video_subtitle }}</p>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</factory-sessions-{{ ai_gen_id }}>

<script>
  (function() {
    class FactorySessions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.thumbnails = this.querySelectorAll('.ai-factory-sessions-thumbnail-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', () => {
            const videoId = thumbnail.dataset.videoId;
            const youtubeId = thumbnail.dataset.youtubeId;
            const video = document.getElementById(videoId);

            if (video) {
              if (youtubeId) {
                video.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1`;
              } else {
                video.play();
              }
              thumbnail.classList.add('ai-factory-sessions-hidden-{{ ai_gen_id }}');
              const playButton = thumbnail.nextElementSibling;
              if (playButton) {
                playButton.classList.add('ai-factory-sessions-hidden-{{ ai_gen_id }}');
              }
            }
          });
        });
      }
    }

    customElements.define('factory-sessions-{{ ai_gen_id }}', FactorySessions{{ ai_gen_id }});
  })();
</script>

